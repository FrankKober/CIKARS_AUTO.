generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(BUYER)
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cars      Car[]      @relation("SellerCars")
  favorites Favorite[]
  recvMsgs  Message[]  @relation("ReceivedMessages")
  sentMsgs  Message[]  @relation("SentMessages")
}

model Car {
  id           String               @id @default(uuid())
  make         String
  model        String
  year         Int
  mileage      Int
  fuelType     String
  transmission String
  price        Float
  location     String               @default("Nairobi")
  description  String
  images       String[]
  vin          String               @unique
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  sellerId     String
  seller       User                 @relation("SellerCars", fields: [sellerId], references: [id], onDelete: Cascade)
  favorites    Favorite[]
  intelligence ListingIntelligence?
}

model ListingIntelligence {
  id                 String    @id @default(uuid())
  carId              String    @unique
  fairPriceScore     DealScore @default(FAIR_PRICE)
  marketAveragePrice Float
  demandScore        Int
  priceHistory       Json
  aiSummary          String?
  car                Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  carId     String
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, carId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  message    String
  timestamp  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum DealScore {
  GREAT_DEAL
  FAIR_PRICE
  OVERPRICED
}
